# dmart — sample config.env
#
# Copy to one of the supported deploy paths and uncomment the keys you want
# to override. Any key NOT listed here falls back to the default declared on
# DmartSettings.cs.
#
# Lookup order (first match wins):
#   1. $BACKEND_ENV (or $DMART_ENV) — explicit path. Use this for dev/CI:
#      `BACKEND_ENV=./config.env ./dmart serve` runs against a repo-local
#      file without needing to drop one in $HOME or /etc.
#   2. ~/.dmart/config.env — per-user install via `dmart init`
#   3. /etc/dmart/config.env — system-wide RPM/DEB install
#
# Cwd-relative `./config.env` is NOT looked up implicitly (a stray file in
# the wrong directory used to silently override the intended config).
#
# Permissions: the file carries JWT_SECRET and DATABASE_PASSWORD, so dmart
# refuses to read it if "other" perms are set. `chmod o-rwx` it after
# editing. `chmod 0640 root:dmart` is the canonical /etc/dmart/config.env
# shape. The admin password is intentionally NOT in this file — see the
# first-run admin bootstrap section below.
#
# Precedence (later wins): appsettings.json < config.env < environment vars
# (Dmart__Xxx).

# ---- application ----
LISTENING_HOST="0.0.0.0"
LISTENING_PORT=5099
# APP_URL — public base URL of the dmart server, used to assemble short-link
#   URLs returned by /managed/short-link. Empty disables short-link assembly.
# APP_URL="https://api.example.com"

# ---- database (individual components; leave POSTGRES_CONNECTION unset to assemble from these) ----
DATABASE_HOST="localhost"
DATABASE_PORT=5432
DATABASE_USERNAME="dmart"
DATABASE_PASSWORD="somepassword"
DATABASE_NAME="dmart"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
# Seconds of socket inactivity before a keepalive probe is sent (also enables
# TCP keepalive). Keeps long-idle connections alive through firewall/NAT idle
# timeouts — important for multi-hour `dmart import --fast` runs. 0 disables.
DATABASE_KEEPALIVE=30
# Alternatively, bypass the component assembly with a raw Npgsql connection string:
# POSTGRES_CONNECTION="Host=localhost;Username=dmart;Password=somepassword;Database=dmart"

# ---- auth ----
# REQUIRED: set a real random secret (>=32 bytes). The server REFUSES to start
# on this 'change-me-…' placeholder — a known signing key lets anyone forge an
# admin token. Generate one with:  openssl rand -hex 32
JWT_SECRET="change-me-change-me-change-me-32b-minimum-length"
JWT_ISSUER="dmart"
JWT_AUDIENCE="dmart"
JWT_ACCESS_EXPIRES=3600
JWT_REFRESH_DAYS=30

# Reject JWTs that lack the token_use claim (tokens minted before the
# 2026-06 hardening; the EOL Python implementation never wrote the claim).
# Leave false until the log warning "Accepted legacy JWT without token_use
# claim" stops appearing for a full JWT_ACCESS_EXPIRES window, then enable —
# it closes the remaining gap in access/refresh token separation.
# JWT_REQUIRE_TOKEN_USE=true

# ---- first-run admin bootstrap ----
# The admin shortname is hardcoded to "dmart" in AdminBootstrap and cannot be
# changed via config.
#
# Admin password is NOT set via config.env on purpose. The recommended
# workflow:
#   1. Install + start dmart — the `dmart` user is created passwordless.
#   2. Set the password explicitly:
#         sudo dmart passwd dmart <strong-password>
#   3. Rotate the same way later. The stored hash in the `users` table is
#      the source of truth; bootstrap doesn't second-guess it on restart.
#
# Why not config.env? Keeping the admin secret out of /etc/dmart/config.env
# means no cleartext credential sits on disk in a file backups + log
# scrapers + ops dashboards all happily slurp up. JWT_SECRET and
# DATABASE_PASSWORD still live here (they have to — dmart needs them on
# every boot before any subsystem is up to ask for them); the admin
# password is the one secret that doesn't, so we don't store it.
#
# Test fixtures (DmartFactory) wire an in-memory Dmart:AdminPassword via
# IConfiguration overrides — they bypass config.env entirely, so dropping
# the on-disk seed doesn't affect them.
#
# If you absolutely need bootstrap-from-config (declarative configuration
# management like Ansible/Salt where introducing a second post-install
# step is awkward), AdminBootstrap still honours `Dmart:AdminPassword`
# from any IConfiguration source, including env vars: set
# `Dmart__AdminPassword=...` in the systemd unit's `Environment=` (or a
# drop-in override) for first-install only, then remove it once
# `dmart passwd` has taken over.
ADMIN_EMAIL="admin@example.com"

# ---- runtime behaviour ----
MANAGEMENT_SPACE="management"
MAX_SESSIONS_PER_USER=5
MAX_FAILED_LOGIN_ATTEMPTS=5
# Seconds an account stays auto-locked after MAX_FAILED_LOGIN_ATTEMPTS before a
# login attempt may clear the lock and retry. Measured from the last failed/blocked
# attempt and refreshed on every attempt while locked, so a persistent attacker
# never auto-unlocks. 0 = permanent lock until an admin resets (pre-cooldown behaviour).
LOCKOUT_COOLDOWN_SECONDS=900
MAX_QUERY_LIMIT=10000
# Per-IP cap on /user/login + /user/otp-request per 60s. Raise for batch
# clients that re-authenticate often; lower for stricter anti-enumeration.
AUTH_RATE_LIMIT_PER_MINUTE=10
# Reverse-proxy trust — REQUIRED for the per-IP rate limit (and access-log
# client IP) to work when dmart runs behind nginx/an LB. List the proxy's exact
# address(es) so X-Forwarded-For is trusted ONLY from there. If unset and dmart
# is behind a non-loopback proxy, every client shares ONE rate-limit bucket;
# if set too broadly, clients in that range can spoof their IP. Comma-separated
# IPs and/or CIDR networks (canonical, e.g. 10.0.0.0/24). Loopback always trusted.
TRUSTED_PROXIES=""
# Number of proxy hops in front of dmart (right-most X-Forwarded-For entries to
# trust). 1 for a single nginx; 2 for CDN → nginx → dmart.
FORWARDED_FOR_HOP_COUNT=1
URL_SHORTER_EXPIRES=3600
IS_REGISTRABLE=true
# IS_OTP_FOR_CREATE_REQUIRED — when true, POST /user/create requires a valid
#   email_otp/msisdn_otp previously obtained via /user/otp-request.
IS_OTP_FOR_CREATE_REQUIRED=true
# OTP_TOKEN_TTL — global TTL (seconds) for one-time passwords; entries older
#   than this are treated as expired regardless of per-endpoint expiry.
OTP_TOKEN_TTL=300
# ALLOW_OTP_RESEND_AFTER — minimum seconds between OTP re-sends to the same
#   destination. /user/otp-request returns HTTP 403 inside this window.
ALLOW_OTP_RESEND_AFTER=60
# SESSION_INACTIVITY_TTL — seconds of idle time before a JWT is rejected and
#   the session row deleted. 0 disables the check.
SESSION_INACTIVITY_TTL=0
# SESSION_MAX_LIFETIME_SECONDS — hard cap on the refresh-token chain measured
#   from the original login. 0 disables the cap.
SESSION_MAX_LIFETIME_SECONDS=0
# LOCK_PERIOD — seconds a PUT /managed/lock stays held before it can be taken
#   by any user (prevents orphaned locks from crashed clients).
LOCK_PERIOD=300
# LOGOUT_ON_PWD_CHANGE — when true, all sessions of a user are invalidated
#   after their password changes.
LOGOUT_ON_PWD_CHANGE=true
# REQUEST_TIMEOUT — outbound HTTP timeout (seconds) for plugins/webhooks.
REQUEST_TIMEOUT=35
# JQ_TIMEOUT — timeout (seconds) for the `jq` subprocess invoked when a join
#   sub-query carries a jq_filter expression.
JQ_TIMEOUT=2
MOCK_OTP_CODE="123456"
MOCK_SMTP_API=false
MOCK_SMPP_API=false

# ---- access control ----
# Enforce folder content policies (content_resource_types,
# content_schema_shortnames, workflow_shortnames in a folder's payload.body)
# on everything created/updated/moved inside that folder. Default TRUE.
# Set false for a dry-run migration window: violations are warn-logged
# ("folder-content policy violation") but allowed. Either way, run
# `dmart check` to list non-compliant content (folder_content_violations).
# ENFORCE_FOLDER_CONTENT_POLICY=false

# ALLOWED_SUBMIT_MODELS — CSV list of "space.schema" pairs allowed for public
#   /submit endpoints. Empty (the C# default) allows nothing — uncomment +
#   list the exact pairs your /submit clients are allowed to write to.
# ALLOWED_SUBMIT_MODELS="public.feedback,public.contact"
# USER_PROFILE_PAYLOAD_PROTECTED_FIELDS — CSV of payload field names users
#   cannot update via POST /user/profile. Empty (the C# default) protects
#   nothing in the payload body — uncomment to harden specific fields.
# USER_PROFILE_PAYLOAD_PROTECTED_FIELDS="role,verified"
# USER_CREATE_DEFAULT_ROLE / USER_CREATE_DEFAULT_GROUP — self-service
#   registration (POST /user/create) always ignores any roles/groups sent in
#   the request body so a user can't grant themselves privileges. When set,
#   every self-created user instead receives exactly this one role and/or
#   group; empty (the C# default) leaves the new user with no role/group.
#   The managed/admin create path is unaffected.
# USER_CREATE_DEFAULT_ROLE="user"
# USER_CREATE_DEFAULT_GROUP="customers"

# ---- external SMS gateway (Python parity) ----
# SMPP_AUTH_KEY — value of the `auth-key` HTTP header sent on every call to
#   SEND_SMS_OTP_API and SEND_SMS_API. Gateway-specific.
# SMPP_AUTH_KEY=""
#
# SMS_SENDER — optional from-name / sender ID shown to recipients. When set,
#   gets inlined as `"sender": "<value>"` in the JSON body of both OTP and
#   general SMS calls. Empty omits the field — leave unset for gateways that
#   reject unknown keys.
# SMS_SENDER=""
#
# SEND_SMS_OTP_API — POST endpoint for OTP SMS delivery.
#   Body: {"msisdn":"...","text":"..."}. Empty → OTPs logged only.
# SEND_SMS_OTP_API=""
#
# SEND_SMS_API — POST endpoint for general SMS delivery to msisdn users.
#   Same body shape as SEND_SMS_OTP_API.
# SEND_SMS_API=""

# ---- SMTP email gateway ----
# Used by OtpProvider for email OTP delivery. Empty MAIL_HOST falls back to
# logging only (same as SMS) — the safer default. Uncomment + fill the trio
# (HOST/USERNAME/PASSWORD) to
# actually send mail. MockSmtpApi short-circuits delivery for dev/CI.
# MAIL_HOST="smtp.example.com"
# MAIL_PORT=587
# MAIL_USERNAME=""
# MAIL_PASSWORD=""
# MAIL_FROM_ADDRESS="noreply@example.com"
# MAIL_FROM_NAME — optional display name for the From header.
# MAIL_FROM_NAME="dmart"
# MAIL_USE_TLS=true

# ---- embeddings (semantic search, opt-in) ----
# Requires the pgvector extension installed in PostgreSQL. When both pgvector
# and EMBEDDING_API_URL are set, dmart embeds every entry on create/update and
# exposes POST /managed/semantic-search + the dmart_semantic_search MCP tool.
# OpenAI-compatible request: POST {url} Bearer {key} {"model":"...","input":"..."}.
# Keep all three lines commented unless you're enabling the feature — the
# model alone has no effect without the URL/key.
# EMBEDDING_API_URL="https://api.openai.com/v1/embeddings"
# EMBEDDING_API_KEY=""
# EMBEDDING_MODEL="text-embedding-3-small"

# ---- OAuth / social login (Google + Facebook) ----
# Leaving a provider's CLIENT_ID blank disables it cleanly (endpoints return
# "provider not configured" rather than attempting outbound calls). The
# Apple Sign In settings live in their own block below — Apple's
# client_secret is itself a signed JWT, so its config shape differs from
# Google/Facebook.
# Google: aud on the id_token must match GOOGLE_CLIENT_ID — used by both the
# code-exchange flow and the mobile id-token flow.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_OAUTH_CALLBACK="https://api.example.com/user/google/callback"
# Facebook: app token sent to /debug_token is the literal "{id}|{secret}".
# FACEBOOK_CLIENT_ID=""
# FACEBOOK_CLIENT_SECRET=""
# FACEBOOK_OAUTH_CALLBACK="https://api.example.com/user/facebook/callback"

# ---- logging ----
# LOG_FORMAT: "text" (default, human-readable) or "json" (structured JSON lines)
#   Under systemd, defaults to "json" automatically (detected via INVOCATION_ID).
#   JSON logs are captured by journald: journalctl -u dmart -f
# LOG_FORMAT="json"
# LOG_FILE: empty = stdout only (goes to journald under systemd). Set a path
#   and the file becomes the authoritative log, JSON Lines format,
#   rotation-aware (see LOG_MAX_BYTES + LOG_BACKUP_COUNT below).
#
#   Under systemd specifically, when LOG_FILE is set the per-request API
#   logs (Dmart.RequestLog + Microsoft.AspNetCore noise) are routed to the
#   file ONLY — journald keeps just the startup banner, warnings, and
#   errors. The intent: an operator who sets a log file does it so they
#   can grep that file; mirroring every "HTTP GET /foo → 200" line to
#   journald just blasts the system journal.
#
#   System install (RPM/DEB/APK): /var/lib/dmart/logs/ is auto-created by
#   the systemd unit's StateDirectory= (and by the install postinst) —
#   drop the log file there to avoid mkdir / chown footwork.
# LOG_FILE="/var/lib/dmart/logs/dmart.ljson.log"
#   Per-user dev run: a relative path resolves against cwd.
# LOG_FILE="logs/dmart.ljson.log"
# LOG_LEVEL: trace, debug, information (default), warning, error, critical, none
# LOG_LEVEL="information"
# LOG_MAX_BYTES: max file size before rotation (default 1073741824 = 1 GB).
#   Set to 0 to disable rotation entirely (file grows unbounded).
# LOG_MAX_BYTES=1073741824
# LOG_BACKUP_COUNT: how rotated archives are managed.
#   < 0 (default) — unlimited: every rollover appends "log.<N+1>"; oldest
#                   archive has lowest N, newest has highest. Operators
#                   handle retention via logrotate / journald / external
#                   archival.
#   = 0           — truncate in place on rollover (no archives kept).
#   > 0           — keep N most recent archives, "log.1" newest..".N" oldest;
#                   shifts on every rollover. Matches Python upstream.
# LOG_BACKUP_COUNT=-1

# ---- frontends ----
# CXB_URL: URL path prefix for the CXB Svelte frontend. Default: /cxb
# Set to "/" to serve at root, or "/admin" for a custom path.
# CXB_URL="/cxb"
# CAT_URL: URL path prefix for the Catalog SPA. Default: /cat
# CAT_URL="/cat"

# ---- channel auth (Python parity: utils/middleware.py::ChannelMiddleware) ----
# When true, requests are gated on the `x-channel-key` header against entries
# in CHANNELS_CONFIG_PATH (default ~/.dmart/channels.json). See
# Middleware/ChannelAuthMiddleware.cs for full semantics.
# ENABLE_CHANNEL_AUTH=false
# CHANNELS_CONFIG_PATH=""

# ---- Apple Sign In (web-callback flow) ----
# Two flows are supported:
#   * Mobile / id-token: client supplies an Apple-issued id_token to
#     POST /user/apple/mobile-login. Requires only APPLE_CLIENT_ID.
#   * Web callback: GET /user/apple/callback receives a `code` from Apple;
#     dmart exchanges it at https://appleid.apple.com/auth/token using a
#     short-lived ES256-signed client_assertion JWT it mints itself from
#     APPLE_P8_PRIVATE_KEY. Requires the full set below.
# APPLE_CLIENT_ID is the Services ID (web) or bundle ID (mobile).
# APPLE_TEAM_ID is the 10-character Apple Developer Team ID.
# APPLE_KEY_ID is the kid of the .p8 signing key.
# APPLE_P8_PRIVATE_KEY is the PEM contents of the .p8 file (newlines may
#   be \n-escaped in .env). dmart re-mints the assertion every 5 minutes,
#   so unlike the upstream Python flow you never need to pre-bake a
#   long-lived client_secret JWT.
# APPLE_OAUTH_CALLBACK is the redirect URI registered with Apple.
# APPLE_CLIENT_ID=""
# APPLE_TEAM_ID=""
# APPLE_KEY_ID=""
# APPLE_P8_PRIVATE_KEY=""
# APPLE_OAUTH_CALLBACK="https://api.example.com/user/apple/callback"

# ---- CORS ----
# Comma-separated list of origins allowed to make cross-site requests.
# Empty (or unset) means: allow only the same-host origin
# http://{LISTENING_HOST}:{LISTENING_PORT}. When non-empty, only listed
# origins get Access-Control-Allow-Origin reflected back.
# ALLOWED_CORS_ORIGINS="http://localhost:3000,https://app.example.com"
