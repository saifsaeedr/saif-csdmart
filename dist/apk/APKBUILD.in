# Generated from dist/apk/APKBUILD.in by dist/build-apk.sh.
# Maintainer: dmart <admin@dmart.cc>

pkgname=dmart
pkgver=__VERSION__
pkgrel=0
pkgdesc="dmart — Unified Data Platform (REST API server + CLI)"
url="https://github.com/edraj/csdmart"
arch="__ARCH__"
license="AGPL-3.0-only"

# jq is invoked as a subprocess when /managed/query carries a jq_filter
# on a join sub-query (mirrors Python dmart). Every other endpoint works
# without it. PostgreSQL itself is intentionally NOT a hard depends —
# dmart talks to a remote PG over TCP just as often as a local one.
depends="jq"

install="$pkgname.pre-install $pkgname.post-install $pkgname.post-deinstall"

source="
	dmart
	dmart.service
	dmart.openrc-init
	dmart.bash
	dmart.fish
	config.env.sample
	plugins.tar.gz
"

# !check — no test phase in this recipe (suite runs in CI before packaging).
# !strip — NativeAOT publish already stripped symbols via -p:StripSymbols=true,
#          and a second `strip` pass on an AOT binary can break exported
#          symbol tables that the runtime resolves at startup.
options="!check !strip"

builddir="$srcdir"

package() {
	# Server binary
	install -Dm755 "$srcdir"/dmart \
		"$pkgdir"/usr/bin/dmart

	# Plugin configs
	mkdir -p "$pkgdir"/usr/lib/dmart/plugins
	tar -xzf "$srcdir"/plugins.tar.gz \
		-C "$pkgdir"/usr/lib/dmart/plugins

	# Config sample
	install -Dm644 "$srcdir"/config.env.sample \
		"$pkgdir"/usr/share/dmart/config.env.sample

	# OpenRC init script (Alpine default service manager)
	install -Dm755 "$srcdir"/dmart.openrc-init \
		"$pkgdir"/etc/init.d/dmart

	# Systemd unit — reference copy for the rare Alpine-with-systemd setup
	# (e.g. via the alpine-init-systemd package). Not enabled on install;
	# OpenRC is the supported path on stock Alpine.
	install -Dm644 "$srcdir"/dmart.service \
		"$pkgdir"/usr/share/dmart/dmart.service

	# Shell completions
	install -Dm644 "$srcdir"/dmart.bash \
		"$pkgdir"/etc/bash_completion.d/dmart
	install -Dm644 "$srcdir"/dmart.fish \
		"$pkgdir"/usr/share/fish/vendor_completions.d/dmart.fish

	# Runtime directories (owned by dmart user, created by pre-install hook)
	install -dm0750 "$pkgdir"/etc/dmart
	install -dm0755 "$pkgdir"/var/lib/dmart
	install -dm0755 "$pkgdir"/var/lib/dmart/spaces
	install -dm0755 "$pkgdir"/var/lib/dmart/custom_plugins
	install -dm0755 "$pkgdir"/var/log/dmart
}

# Checksums are regenerated by `abuild checksum` in dist/build-apk.sh
# before the build step. Left empty here on purpose — the template
# would otherwise carry stale values that drift every release.
sha512sums=""
